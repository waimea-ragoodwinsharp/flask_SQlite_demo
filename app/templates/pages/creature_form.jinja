{#=====================================================
  add a new creature page
=====================================================#}

{% extends 'pages/_base.jinja' %}


{% block content %}

    <h2>New Creature</h2>

    <form method="post" action="/creature/new">
        <label>
            name 
            <input type="text" name="name" required> 
            
        </label>
        <label>
            species
            <input type="text" species="species" required>
            
    </label>

    <button>Add creature</button>

    </form>

 

{% endblock %}

